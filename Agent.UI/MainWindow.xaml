<Window x:Class="Agent.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="M1 Agent - Диагностика"
        Height="500" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#f5f5f5" Foreground="#1a1a1a">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Диагностика системы" FontSize="18" FontWeight="Bold" Foreground="#0078d4" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1">
            <CheckBox x:Name="CpuCheck" Content="Процессор (CPU)" Margin="0,3" IsChecked="True"/>
            <CheckBox x:Name="RamCheck" Content="Память (RAM)" Margin="0,3" IsChecked="True"/>
            <CheckBox x:Name="DiskCheck" Content="Диски" Margin="0,3" IsChecked="True"/>
            <CheckBox x:Name="NetCheck" Content="Сеть" Margin="0,3" IsChecked="True"/>
        </StackPanel>

        <TextBox Grid.Row="2" x:Name="ResultBox" IsReadOnly="True" 
                 Background="#fff" BorderBrush="#ccc" FontFamily="Consolas" FontSize="12"
                 VerticalScrollBarVisibility="Auto" Margin="0,10" TextWrapping="NoWrap"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Собрать" Click="Collect_Click" Background="#0078d4" Foreground="White" 
                    Padding="20,8" Margin="5" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Закрыть" Click="Close_Click" Background="#ccc" Foreground="#333" 
                    Padding="20,8" Margin="5" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>