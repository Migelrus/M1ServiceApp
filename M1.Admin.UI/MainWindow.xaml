<Window x:Class="M1.Admin.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="M1 Admin Console"
        Height="700" Width="1050"
        MinHeight="500" MinWidth="800"
        Background="#f0f2f5" Foreground="#1a1a1a"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <!-- ЭКРАН ВХОДА -->
        <Border x:Name="LoginPanel" Background="#ffffff" Visibility="Visible">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="380">
                <StackPanel>
                    <TextBlock Text="M1 Admin" FontSize="28" FontWeight="Bold" Foreground="#1a1a1a" Margin="0,0,0,5"/>
                    <TextBlock Text="Вход в панель управления" FontSize="14" Foreground="#888" Margin="0,0,0,30"/>
                    <TextBlock Text="Адрес сервера" Foreground="#666" Margin="0,0,0,4"/>
                    <TextBox x:Name="ServerBox" Text="http://192.168.1.85:5230"
                             Background="#f5f5f5" BorderBrush="#e0e0e0" Padding="10" FontSize="13" Margin="0,0,0,12">
                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                    </TextBox>
                    <TextBlock Text="Логин" Foreground="#666" Margin="0,0,0,4"/>
                    <TextBox x:Name="LoginBox" Background="#f5f5f5" BorderBrush="#e0e0e0" Padding="10" FontSize="13" Margin="0,0,0,12">
                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                    </TextBox>
                    <TextBlock Text="Пароль" Foreground="#666" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PasswordBox" Background="#f5f5f5" BorderBrush="#e0e0e0" Padding="10" FontSize="13" Margin="0,0,0,12">
                        <PasswordBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></PasswordBox.Resources>
                    </PasswordBox>
                    <CheckBox x:Name="RememberCheck" Content="Запомнить" Foreground="#888" Margin="0,0,0,15"/>
                    <TextBlock x:Name="LoginError" Foreground="#d32f2f" FontSize="12" Margin="0,0,0,10" Visibility="Collapsed"/>
                    <Button Content="Войти" Click="Login_Click" Background="#1a1a1a" Foreground="White" Padding="0,12" FontSize="14" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ЭКРАН АДМИН-ПАНЕЛИ -->
        <Grid x:Name="AdminPanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель — сети -->
            <Border Grid.Column="0" Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="0,0,1,0">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Сети" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Button Grid.Row="1" Content="+ Новая" Click="AddNetwork_Click"
                            Background="#1a1a1a" Foreground="White" Padding="0,8" FontSize="12" BorderThickness="0" Cursor="Hand" Margin="0,0,0,10">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                    </Button>

                    <ListBox Grid.Row="2" x:Name="NetworksList" Background="Transparent" BorderThickness="0"
                             SelectionChanged="NetworksList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,1" CornerRadius="6" Background="#f8f9fa">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Background="#0078d4" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Devices}" FontSize="11" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="3" Padding="8" CornerRadius="6" Background="#f8f9fa" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ServerStatusIndicator" Width="6" Height="6" Fill="#4caf50" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ServerStatusText" Text="Подключено" FontSize="11" Foreground="#666"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Правая панель — устройства -->
            <Border Grid.Column="1" Background="#ffffff">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock x:Name="SelectedNetworkText" Text="Все устройства" FontSize="18" FontWeight="Bold"/>
                        <TextBlock x:Name="DeviceCountText" Text="" FontSize="13" Foreground="#888" Margin="10,4,0,0"/>
                    </StackPanel>

                    <Button Grid.Row="1" Content="↻ Обновить" Click="RefreshDevices_Click"
                            Background="#f0f2f5" Foreground="#1a1a1a" Padding="10,6" BorderThickness="0"
                            Cursor="Hand" HorizontalAlignment="Left" FontSize="11">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                    </Button>

                    <ListView Grid.Row="2" x:Name="DevicesList" Background="Transparent" BorderThickness="0" Margin="0,8,0,0">
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="🦀 RustDesk — подключиться" Click="RustDeskDevice_Click"/>
                                <Separator/>
                                <MenuItem Header="📊 Диагностика" Click="DiagnosticDevice_Click"/>
                                <MenuItem Header="🖵 Скриншот экрана" Click="ScreenshotDevice_Click"/>
                                <Separator/>
                                <MenuItem Header="⬛ Отправить команду..." Click="SendCustomCmd_Click"/>
                                <MenuItem Header="🖥 Управление ПК" Click="CompMgmtDevice_Click"/>
                                <MenuItem Header="🖥 Диспетчер задач" Click="TaskMgrDevice_Click"/>
                                <Separator/>
                                <MenuItem Header="🔄 Перезапустить проводник" Click="RestartExplorerDevice_Click"/>
                                <Separator/>
                                <MenuItem Header="📋 Копировать ID" Click="CopyId_Click"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="" Width="35">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="7" Height="7" Fill="{Binding StatusBrush}" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Устройство" Width="140" DisplayMemberBinding="{Binding PcName}"/>
                                <GridViewColumn Header="RustDesk ID" Width="120" DisplayMemberBinding="{Binding RustDeskId}"/>
                                <GridViewColumn Header="Сеть" Width="100" DisplayMemberBinding="{Binding NetworkName}"/>
                                <GridViewColumn Header="ОС" Width="150" DisplayMemberBinding="{Binding OsVersion}"/>
                                <GridViewColumn Header="Активность" Width="130" DisplayMemberBinding="{Binding LastSeenText}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>