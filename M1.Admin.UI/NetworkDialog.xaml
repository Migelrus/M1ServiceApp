<Window x:Class="M1.Admin.UI.NetworkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание сети" Height="300" Width="420"
        WindowStartupLocation="CenterOwner" Background="#f5f5f5"
        ResizeMode="NoResize">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Новая сеть" FontSize="20" FontWeight="Bold" Foreground="#1a1a1a" Margin="0,0,0,5"/>
        <TextBlock Grid.Row="1" Text="Сеть объединяет агентов в изолированную группу" FontSize="12" Foreground="#888" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="2" Text="Название сети" Foreground="#666" Margin="0,0,0,4"/>
        <TextBox Grid.Row="2" x:Name="NameBox" Background="#fff" BorderBrush="#e0e0e0" Padding="10" FontSize="13" Margin="0,0,0,12" VerticalAlignment="Bottom"/>

        <TextBlock Grid.Row="3" Text="Пароль" Foreground="#666" Margin="0,0,0,4"/>
        <TextBox Grid.Row="3" x:Name="PasswordBox" Background="#fff" BorderBrush="#e0e0e0" Padding="10" FontSize="13" Margin="0,0,0,12" VerticalAlignment="Bottom"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
            <TextBlock x:Name="ErrorText" Foreground="#d32f2f" FontSize="12" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <Button Content="Отмена" Click="Cancel_Click" Background="#f0f2f5" Foreground="#1a1a1a" Padding="20,8" Margin="5" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Создать" Click="Create_Click" Background="#1a1a1a" Foreground="White" Padding="20,8" Margin="5" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>